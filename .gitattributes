# Normalize line endings: text files are LF in the repo and on checkout, regardless of the
# contributor's core.autocrlf. Keeps Windows dev and Linux CI byte-identical.
* text=auto eol=lf

# Windows-only scripts keep CRLF
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary assets — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.pdf binary
